# Ingest 标记（可重建）
.ingested/

# 大型原始文件（PDF等）— 所有 raw 子目录下的 PDF
*.pdf
**/raw/reports/
**/raw/research/
**/raw/financial_reports/
**/raw/prospectus/
**/raw/investor_relations/
**/raw/announcements/

# Python 缓存
__pycache__/
*.pyc
*.pyo

# 系统文件
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# 环境变量
.env

# 配置文件（可能含敏感信息，用户应自行维护）
# config.yaml 模板参见 config.yaml.example（如需）
# 建议从环境变量读取 API Key，不在 config.yaml 中明文存储

# 临时文件
*.tmp
*.swp
*~
